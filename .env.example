# ----------------------------------------------------------------------------
# Configuration for the Website Automation Agent
# Copy this file to ".env" and fill in your values.
# ----------------------------------------------------------------------------

# ---- Providers -------------------------------------------------------------
# At least ONE provider key is required. If both are set, the agent uses them
# in PROVIDER_ORDER and automatically falls back to the next one when a provider
# is rate-limited or errors.

# Provider 1: Google Gemini (free) -> https://aistudio.google.com/apikey
GEMINI_API_KEY=
# gemini-2.0-flash has a higher free-tier rate limit; gemini-2.5-flash is smarter.
LLM_MODEL=gemini-2.0-flash

# Provider 2: Groq (free, very fast) -> https://console.groq.com/keys
GROQ_API_KEY=
GROQ_MODEL=meta-llama/llama-4-scout-17b-16e-instruct

# Which providers to try, in order. The agent falls back left-to-right.
# Examples: "gemini,groq" (accuracy first) or "groq,gemini" (speed first).
PROVIDER_ORDER=gemini,groq

# The page the agent should operate on.
TARGET_URL=https://ui.shadcn.com/docs/forms/react-hook-form

# Natural-language goal for the agent. Nothing is hardcoded — the agent reads
# this and figures out how to accomplish it by looking at the page.
TASK=Locate the form on the page. Fill in the "Name" field and the "Description" field with realistic sample values, then stop.

# Optional explicit values. Leave blank to let the agent invent sensible ones.
FORM_NAME=
FORM_DESCRIPTION=

# Run the browser visibly (true) or headless (false). Visible is better for a demo.
HEADED=true

# Viewport size (pixels). Coordinates the agent clicks are in this space.
VIEWPORT_WIDTH=1280
VIEWPORT_HEIGHT=800

# Safety limit on how many reasoning/action steps the agent may take.
MAX_STEPS=18

# Where screenshots are written.
SCREENSHOT_DIR=screenshots
